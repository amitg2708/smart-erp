# Smart College ERP — Environment Variables Example
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/college_erp

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Smart College ERP <your_email@gmail.com>

# ─── OR: Custom SMTP ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password

# ─── App URL (for email links) ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
PROD_URL=https://your-erp-domain.com

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ─── Multi-Tenant (optional, if multi-college is enabled) ──────────────────────
# DEFAULT_COLLEGE_CODE=DEFAULT
