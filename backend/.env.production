PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/college_erp_prod
JWT_SECRET=CHANGE_THIS_TO_VERY_STRONG_SECRET_IN_PRODUCTION
JWT_EXPIRES_IN=1d
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Smart College ERP <noreply@college.edu>
CLIENT_URL=https://your-erp-domain.com
PROD_URL=https://your-erp-domain.com
LOG_LEVEL=warn
MAX_FILE_SIZE_MB=5
